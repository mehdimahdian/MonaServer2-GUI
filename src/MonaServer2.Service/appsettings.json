{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      }
    }
  },
  "MonaServer": {
    "ExecutablePath": "",
    "WorkingDirectory": "",
    "ConfigPath": "",
    "ApiBaseUrl": "http://localhost:80",
    "ApiAdminPath": "/admin/api",
    "ApiTimeoutMs": 3000,
    "AutoStart": true,
    "AutoRestart": true,
    "RestartDelayMs": 5000,
    "PollIntervalMs": 2000
  },
  "Streaming": {
    "FfmpegPath": "",
    "DefaultRtmpUrl": "rtmp://localhost:1935/live",
    "DefaultStreamKey": "stream",
    "DefaultVideoBitrateKbps": 2500,
    "PreviewFrameTimeoutMs": 5000
  },
  "Update": {
    "GitHubRepo": "MonaSolutions/MonaServer2",
    "InstallDirectory": "",
    "WindowsAssetPattern": "windows",
    "LinuxAssetPattern": "linux",
    "MacOsAssetPattern": "macos"
  },
  "Service": {
    "Port": 8080,
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 10,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
